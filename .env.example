# Copy to `.env` and adjust. Used by docker-compose.yml.

# Domain for the hosted instance. With a real domain pointed at this server
# (DNS A/AAAA record) and ports 80 + 443 open, Caddy automatically provisions
# and renews HTTPS certificates via Let's Encrypt - no extra config.
#
# For local testing, leave it as ":80" to serve plain HTTP at http://127.0.0.1
DOMAIN=:80
# Production example:
# DOMAIN=pcb.example.com

# Optional: to get Let's Encrypt expiry-warning emails, add this line to the top
# of the Caddyfile instead:   { email you@example.com }
